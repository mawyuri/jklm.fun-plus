{
	"name": "JKLM.fun+",
	"description": "QoL improvements and extra features for JKLM.fun",
	"version": "1.0",
	"manifest_version": 3,
	"icons":
	{
		"16": "images/16.png",
		"32": "images/32.png",
		"48": "images/48.png",
		"128": "images/128.png"
	},
	"background": {
		"service_worker": "scripts/background.js"
	},
	"content_scripts": [
		{
			"js": ["scripts/content.js"],
			
			"matches": ["https://jklm.fun/*"],
			"world": "MAIN"
		}
	],
	"web_accessible_resources": [{
		"resources": ["scripts/content.js"],
		"matches": ["https://jklm.fun/*"]
	}]
}
