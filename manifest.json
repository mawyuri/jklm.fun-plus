{
	"name": "JKLM.fun+",
	"description": "QoL improvements and extra features for JKLM.fun",
	"version": "1.1.0",
	"manifest_version": 3,
	"icons":
	{
		"16": "src/images/16.png",
		"32": "src/images/32.png",
		"48": "src/images/48.png",
		"128": "src/images/128.png"
	},
	"content_scripts": [
		{
			"js": ["src/loader.js"],
			"matches": ["https://jklm.fun/*"]
		}
	]
}
